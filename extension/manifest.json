{
  "manifest_version": 3,
  "name": "Billable Lens",
  "version": "1.0.0",
  "description": "See billable vs non-billable hours at a glance on Scoro timesheets — a green check or red X on each time entry.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "Billable Lens"
  },
  "content_scripts": [
    {
      "matches": ["https://*.scoro.com/tasks/timesheet*"],
      "js": ["content.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ]
}
